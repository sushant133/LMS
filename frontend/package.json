{
  "name": "@nepal-school-erp/frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:shared": "npm install --include=dev --prefix ../backend/shared && npm run build --prefix ../backend/shared",
    "dev": "npm run build:shared && node scripts/dev.mjs",
    "dev:client": "npm run build:shared && vite",
    "build": "npm run build:shared && node scripts/sync-vercel-config.mjs && tsc -b && vite build",
    "start": "vite preview --host",
    "prestart": "npm run build",
    "preview": "vite preview",
    "typecheck": "npm run build:shared && tsc --noEmit",
    "lint": "npm run build:shared && tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@munatech/nepali-datepicker": "1.2.3",
    "@nepal-school-erp/shared": "file:../backend/shared",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-query": "5.90.5",
    "axios": "1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "i18next": "25.5.2",
    "lucide-react": "^0.542.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "15.7.3",
    "react-router-dom": "6.30.1",
    "recharts": "^3.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.3",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.8.3",
    "vite": "^7.1.4"
  }
}
###############################################################################
# PHIT LMS / ERP — Frontend environment template
#
# Copy to frontend/.env for local overrides (optional).
# Development works out of the box with Vite proxy → local backend.
# Do not put production domains here until deploy day.
###############################################################################

# API base (includes /api). Localhost uses Vite proxy to the backend.
VITE_API_URL=/api

# Optional product name
# VITE_APP_NAME=PHIT COLLEGE

# Dev-only: backend origin for Vite /api and /uploads proxy (default below)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000

###############################################################################
# FUTURE PRODUCTION BUILD (Hostinger + Nginx reverse proxy — recommended)
#
# Build with same-origin /api so auth cookies work behind Nginx:
#   VITE_API_URL=/api
#   npm run build
# Serve frontend/dist via Nginx; proxy /api and /uploads to Node.
#
# Split API host (only if frontend and API are different origins):
#   VITE_API_URL=https://api.yourdomain.com/api
#   And set backend COOKIE_SAME_SITE=none + COOKIE_SECURE=true
###############################################################################

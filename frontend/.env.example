# Local dev — Vite proxies /api and /uploads to the backend (see vite.config.ts)
VITE_API_BASE_URL=/api

# --- Vercel production ---
# Set this in Vercel Project Settings > Environment Variables.
# Use your Render backend URL (include /api suffix):
# VITE_API_BASE_URL=https://nepal-school-erp-api.onrender.com/api
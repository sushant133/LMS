# Local dev — Vite proxies /api and /uploads to the backend (see vite.config.ts)
VITE_API_URL=/api

# --- Vercel production ---
# Root Directory in Vercel must be set to: frontend
# No environment variables are required — defaults are in deployment.config.js
# Optional overrides:
#   VITE_API_URL=/api
#   BACKEND_URL=https://lms-s7tz.onrender.com
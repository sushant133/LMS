# Local dev — Vite proxies /api and /uploads to the backend (see vite.config.ts)
VITE_API_URL=/api

# --- Vercel production ---
# Root Directory in Vercel must be set to: frontend
# IMPORTANT: Do NOT set VITE_API_URL to the Render URL on Vercel.
# The browser must call same-origin /api (proxied by vercel.json) or auth cookies will not work.
# Remove VITE_API_URL from Vercel env vars entirely, or set it to: /api
# Optional:
#   BACKEND_URL=https://lms-s7tz.onrender.com
#
# --- Render production ---
# Keep SEED_DEMO=true so demo data is created/repaired on each deploy startup.
{
  "name": "@phit-erp/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:shared": "npm install --include=dev --prefix ./shared && npm run build --prefix ./shared",
    "dev": "npm run build:shared && tsx watch src/server.ts",
    "build": "npm run build:shared && tsc -p tsconfig.json",
    "postinstall": "npm run build",
    "start": "node dist/server.js",
    "seed:superadmin": "npm run build:shared && tsx src/scripts/seedSuperAdmin.ts",
    "seed:demo": "npm run build:shared && tsx src/scripts/seedDemoSchool.ts",
    "typecheck": "npm run build:shared && tsc -p tsconfig.json --noEmit",
    "lint": "npm run build:shared && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@phit-erp/shared": "file:./shared",
    "@types/sharp": "^0.31.1",
    "bcryptjs": "3.0.2",
    "cloudinary": "^2.10.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "express": "5.1.0",
    "fs-extra": "^11.3.5",
    "jsonwebtoken": "9.0.2",
    "mongoose": "^8.24.1",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nepali-date-converter": "^3.3.1",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.18.0",
    "sharp": "^0.35.3",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.9",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.15.21",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}

PORT=5000
# IMPORTANT: This project requires MongoDB running as a Replica Set (even for local dev)
# because it uses multi-document transactions.
# Local replica set:
# MONGODB_URI=mongodb://127.0.0.1:27017/nepal-school-erp?replicaSet=rs0
# MongoDB Atlas (replica set + SSL):
MONGODB_URI=mongodb://<username>:<password>@<cluster-host>/<database>?ssl=true&replicaSet=<replica-set>&authSource=admin
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
COOKIE_SECRET=replace-with-a-cookie-secret
CORS_ORIGINS=http://localhost:5173
COOKIE_NAME=nepal_school_erp_token
ACTIVE_SCHOOL_COOKIE_NAME=nepal_school_erp_active_school
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
NODE_ENV=development
SEED_DEMO=true
DEFAULT_USER_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=System Super Admin
SUPER_ADMIN_EMAIL=superadmin@nepal-school.com
SUPER_ADMIN_PASSWORD=Admin@123456

# Public frontend URL used in login-credential emails (defaults to first CORS origin)
APP_URL=http://localhost:5173

# SMTP — automatic welcome / login account emails
# IMPORTANT (spam / inbox delivery):
# - Free Gmail SMTP often lands in Spam for automated messages. Prefer Google Workspace
#   or a transactional provider (Resend, SendGrid, Amazon SES, Mailgun) with your college domain.
# - SMTP_FROM_EMAIL must match the authenticated mailbox (especially for Gmail).
# - Add SPF + DKIM + DMARC DNS records for your domain (provider docs).
# - Ask recipients to mark "Not spam" / add sender to contacts once.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_EMAIL=your-smtp-user@gmail.com
SMTP_FROM_NAME=Public Himal Institute of Technology
# Optional monitored reply address (defaults to From)
# SMTP_REPLY_TO=admin@your-college.edu.np

# --- Render production (https://lms-s7tz.onrender.com) ---
# Do NOT commit a .env file. In Render: Service → Environment → "Add from .env"
# Paste the block below (replace placeholders). Render also injects PORT automatically.
#
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
# JWT_SECRET=<at-least-16-characters>
# JWT_EXPIRES_IN=7d
# COOKIE_SECRET=<at-least-8-characters>
# CORS_ORIGINS=http://localhost:5173,https://lms-eulz.vercel.app
# COOKIE_NAME=nepal_school_erp_token
# ACTIVE_SCHOOL_COOKIE_NAME=nepal_school_erp_active_school
# COOKIE_SAME_SITE=lax
# COOKIE_SECURE=true
# NODE_ENV=production
# SEED_DEMO=true
# UPLOAD_DIR=/var/data/uploads
# (Optional) Mount a Render persistent disk at /var/data for uploads that survive redeploys.
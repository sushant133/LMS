###############################################################################
# PHIT LMS / ERP — Backend environment template
#
# Copy to backend/.env for local development (do not commit .env).
# Development defaults keep localhost + MongoDB Atlas (or local replica set).
# Production (Hostinger VPS) values are documented in DEPLOYMENT.md — set only
# when you deploy; do not replace local values until then.
###############################################################################

# --- Runtime ---
NODE_ENV=development
PORT=5000
# Bind address: 0.0.0.0 (default) or 127.0.0.1 when only Nginx on the same host should connect
HOST=0.0.0.0
# Reverse proxy hops (Nginx). Auto: 0 in development, 1 in production if unset
# TRUST_PROXY=0
LOG_LEVEL=debug

# --- Database (any standard MongoDB URI — Atlas, local, or future VPS MongoDB) ---
# IMPORTANT: This project uses multi-document transactions → MongoDB must be a replica set.
#
# Local replica set example:
# MONGODB_URI=mongodb://127.0.0.1:27017/nepal-school-erp?replicaSet=rs0
#
# MongoDB Atlas (current development — keep using this until VPS migration):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
#
# Future Hostinger VPS MongoDB (example only — do not enable until deploy day):
# MONGODB_URI=mongodb://erp_user:<password>@127.0.0.1:27017/nepal-school-erp?replicaSet=rs0&authSource=admin

# --- Auth / cookies ---
JWT_SECRET=replace-with-a-strong-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
# Optional separate secret for future refresh tokens (falls back to JWT_SECRET)
# JWT_REFRESH_SECRET=
# JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=replace-with-a-cookie-secret
COOKIE_NAME=nepal_school_erp_token
ACTIVE_SCHOOL_COOKIE_NAME=nepal_school_erp_active_school
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
# Optional shared cookie domain for production multi-subdomain setups
# COOKIE_DOMAIN=.yourdomain.com

# --- CORS (comma-separated exact origins; never use *) ---
CORS_ORIGINS=http://localhost:5173

# --- Public URLs ---
# Frontend URL for credential emails / login links.
# IMPORTANT: Use your public HTTPS frontend (not localhost) when sending real student mail.
# Localhost links in emails are treated as phishing and land in Spam.
# APP_URL=http://localhost:5173
APP_URL=https://lms-eulz.vercel.app
# Optional public API origin (diagnostics / absolute helpers)
# PUBLIC_API_URL=http://localhost:5000

# --- File uploads (student/teacher photos, documents, certificates, reports) ---
# Leave unset to use ./uploads relative to the backend process cwd
# UPLOAD_DIR=C:\path\to\uploads
# Production VPS example:
# UPLOAD_DIR=/var/www/phit-erp/uploads
#
# --- Cloudinary (images only: profile photos, staff photos, banners) ---
# When all three are set, IMAGE uploads go to Cloudinary CDN.
# PDFs, documents, and videos always stay on local disk (UPLOAD_DIR).
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# Optional root folder prefix (default: phit-erp)
# CLOUDINARY_FOLDER=phit-erp

# --- Demo seed ---
SEED_DEMO=true
DEFAULT_USER_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=System Super Admin
SUPER_ADMIN_EMAIL=superadmin@nepal-school.com
SUPER_ADMIN_PASSWORD=Admin@123456

# --- SMTP (credential / welcome emails) ---
# For Primary inbox delivery:
# 1) Prefer college domain SMTP (Hostinger / Google Workspace / SendGrid) over free @gmail.com
# 2) SMTP_FROM_EMAIL must match SMTP_USER on Gmail
# 3) APP_URL must be public HTTPS (see above)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_EMAIL=your-smtp-user@gmail.com
SMTP_FROM_NAME=Public Himal Institute of Technology
# SMTP_REPLY_TO=admin@your-college.edu.np

# --- Feature flags ---
# SUBJECT_ASSIGNMENT_SCOPE_DEFAULT=legacy
# SUBJECT_ASSIGNMENT_TIMETABLE_REQUIRE_LINK=false

###############################################################################
# FUTURE PRODUCTION (Hostinger VPS) — copy & fill on deploy day only
# See root DEPLOYMENT.md and deploy/examples/
###############################################################################
# NODE_ENV=production
# PORT=5000
# HOST=127.0.0.1
# TRUST_PROXY=1
# LOG_LEVEL=info
# MONGODB_URI=mongodb://erp_user:<password>@127.0.0.1:27017/nepal-school-erp?replicaSet=rs0&authSource=admin
# JWT_SECRET=<generate-long-random-string>
# COOKIE_SECRET=<generate-long-random-string>
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=lax
# CORS_ORIGINS=https://yourdomain.com
# APP_URL=https://yourdomain.com
# PUBLIC_API_URL=https://yourdomain.com
# UPLOAD_DIR=/var/www/phit-erp/uploads
# SEED_DEMO=false
